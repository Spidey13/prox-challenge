# Required: Anthropic API key (Claude Haiku + Sonnet via direct API).
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required for ingestion (Gemini vision + Vertex embeddings).
# Not required for serving if chroma_db/ and assets/ are already present.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: Vertex region for Gemini + embeddings (default us-central1).
VERTEX_LOCATION=us-central1

# Auth for Vertex (ingestion only). Use one of:
#   gcloud auth application-default login
#   GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Optional model overrides (direct Anthropic API IDs).
# HAIKU=claude-haiku-4-5-20251001
# SONNET=claude-sonnet-4-5-20250929
# GEMINI=gemini-2.5-flash

# Frontend CORS (production Cloud Run deployment).
FRONTEND_URL=https://your-app.vercel.app

# Ingestion tuning (all optional — defaults shown).
# Number of pages to process in parallel (respects Gemini RPM via semaphore).
INGEST_WORKERS=3
# Max total tokens per Vertex embedding API batch call.
# Set to 15000 (not 20000) to account for tokenizer differences between
# tiktoken (used for estimation) and Vertex's internal tokenizer.
EMBED_BATCH_TOKEN_LIMIT=15000
# Max tokens per single chunk input to the embedding model (hard API limit).
EMBED_MAX_INPUT_TOKENS=2000

# Product registry file path (default: products.json in the project root).
# Add entries to products.json to register new products — no code changes needed.
PRODUCTS_FILE=products.json
